# --- Database Configuration ---
# Used by Docker Compose to initialize the PostgreSQL container
DB_PASSWORD=your_secure_password_here

# Used by FastAPI/SQLAlchemy to connect to the database via Docker network
DATABASE_URL=postgresql://admin:your_secure_password_here@db:5432/ticket_db

# --- Connection Pool Configuration ---
# Tune these based on your PostgreSQL max_connections setting.
# Defaults are 5 and 10 to protect free-tier deployments.
POOL_SIZE=5
MAX_OVERFLOW=10

# --- JWT Security ---
SECRET_KEY=generate_a_secure_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30